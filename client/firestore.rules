rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAuthorizedAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'singhmanohar6699@gmail.com' || 
        request.auth.token.email == 'nisxsingh6356@gmail.com'
      );
    }
    
    function isAdminApproved() {
      return isAuthorizedAdmin() && getUserData().adminApproved == true;
    }
    
    function isManager() {
      return isAdminApproved() || hasRole('manager');
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      // Only authorized admins can change roles or approval status
      allow write: if request.auth.uid == userId || isAdminApproved();
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdminApproved();
    }

    // Tenders
    match /tenders/{tenderId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminApproved();
    }

    // Inventory
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdminApproved();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAuthorizedAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; // Audit logs are immutable
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, write: if request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId;
    }
  }
}

